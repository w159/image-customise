{
    "Description": "Default user profile settings for all Windows editions",
    "MinimumBuild": "10.0.14393",
    "MaximumBuild": "10.0.99999",
    "Targets": {
        "Platforms": [
            "client",
            "multisession",
            "rds-server",
            "server"
        ],
        "Models": [
            "physical",
            "virtual"
        ]
    },
    "MachineRegistry": {
        "ChangeOwner": [],
        "Set": [],
        "Remove": []
    },
    "UserRegistry": {
        "Set": [
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Network\\Persistent Connections",
                "name": "SaveConnections",
                "value": "No",
                "type": "String",
                "note": "Prevents persistent mapped drives in Explorer. Assumes scripts or GPP are used to map network drives",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo",
                "name": "Enabled",
                "value": 0,
                "type": "DWord",
                "note": "Turns off the feature that lets apps use the advertising ID",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\AppHost",
                "name": "EnableWebContentEvaluation",
                "value": 1,
                "type": "DWord",
                "note": "Turns on Smart Screen for apps",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
                "name": "SystemPaneSuggestionsEnabled",
                "value": 0,
                "type": "DWord",
                "note": "Disables app suggestions in the Start menu",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
                "name": "SilentInstalledAppsEnabled",
                "value": 0,
                "type": "DWord",
                "note": "Disables app suggestions in the Start menu",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search",
                "name": "BingSearchEnabled",
                "value": 0,
                "type": "DWord",
                "note": "Disables web search in the Start menu for better responsiveness",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "LaunchTo",
                "value": 1,
                "type": "DWord",
                "note": "Configures File Explorer to start on This PC",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "HideFileExt",
                "value": 0,
                "type": "DWord",
                "note": "Enables the display of file extensions in File Explorer",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "SeparateProcess",
                "value": 1,
                "type": "DWord",
                "note": "Runs File Explorer windows in different processes so that one window crash won't affect all windows",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "TaskbarGlomLevel",
                "value": 0,
                "type": "DWord",
                "note": "Configures Taskbar buttons on the primary monitor to combine when the Taskbar is full",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "MMTaskbarGlomLevel",
                "value": 0,
                "type": "DWord",
                "note": "Configures Taskbar buttons on secondary monitors to combine when the Taskbar is full",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "Start_IrisRecommendations",
                "value": 0,
                "type": "DWord",
                "note": "Remove 'Recommendations for tips, shortcuts, new apps, and more' in the Start menu",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\People",
                "name": "PeopleBand",
                "value": 0,
                "type": "DWord",
                "note": "Removes the People icon from the Taskbar on Windows 10",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\UserProfileEngagement",
                "name": "ScoobeSystemSettingEnabled",
                "value": 0,
                "type": "DWord",
                "note": "Disable 'Suggest ways to get the most out of Windows and finish setting up this device' Screen in Settings / System / Notifications",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search",
                "name": "SearchboxTaskbarMode",
                "value": 3,
                "type": "DWord",
                "note": "Collapses the Search box into an icon on the Taskbar",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search",
                "name": "SearchboxTaskbarModeCache",
                "value": 3,
                "type": "DWord",
                "note": "Required to support the setting selected for SearchboxTaskbarMode",
                "protected": false
            },
            {
                "path": "HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\CapabilityAccessManager\\ConsentStore\\location\\NonPackaged",
                "name": "Value",
                "value": "Allow",
                "type": "String",
                "note": "Enables location services for Win32 applications",
                "protected": false
            },
            {
                "path": "HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\CapabilityAccessManager\\ConsentStore\\location",
                "name": "Value",
                "value": "Allow",
                "type": "String",
                "note": "Enables location services for Universal Windows Platform Apps",
                "protected": false
            },
            {
                "path": "HKCU:\\Control Panel\\Accessibility",
                "name": "MessageDuration",
                "value": "30",
                "type": "DWord",
                "note": "Increase the timeout for new notifications - Dismiss notifications after this amount of time",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Adobe\\Acrobat Reader\\DC\\AVAlert\\cCheckbox",
                "name": "iAppDoNotTakePDFOwnershipAtLaunchWin10",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the default file type dialog box at Adobe Acrobat Reader DC first launch",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Adobe\\Adobe Acrobat\\DC\\AVAlert\\cCheckbox",
                "name": "iAppDoNotTakePDFOwnershipAtLaunchWin10",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the default file type dialog box at Adobe Acrobat Pro/Standard DC first launch",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\DWM",
                "name": "ColorPrevalence",
                "value": 1,
                "type": "DWord",
                "note": "Enables 'Show accent colour on title bars and window borders'",
                "protected": false
            }
        ],
        "Others": [
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\AutoplayHandlers",
                "name": "DisableAutoplay",
                "value": 1,
                "type": "DWord",
                "note": "Disables 'Settings / Bluetooth & Devices / AutoPlay / Use AutoPlay for all media and devices",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Start",
                "name": "ShowFrequentList",
                "value": 1,
                "type": "DWord",
                "note": "Enables 'Settings / Personalization / Start / Show the most used apps'",
                "protected": false
            }
        ]
    },
    "Paths": {
        "Remove": []
    },
    "Features": {
        "Disable": []
    },
    "Capabilities": {
        "Remove": [],
        "Others": []
    },
    "Packages": {
        "Remove": []
    },
    "Shortcuts": {
        "Edit": []
    },
    "Services": {
        "Restart": [],
        "Stop": [],
        "Start": []
    },
    "Files": {
        "Copy": []
    }
}