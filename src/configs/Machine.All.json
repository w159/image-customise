{
    "Description": "Computer level settings for all Windows 10 and above.",
    "MinimumBuild": "10.0.14393",
    "MaximumBuild": "10.0.99999",
    "Targets": {
        "Platforms": [
            "client",
            "multisession",
            "rds-server",
            "server"
        ],
        "Models": [
            "physical",
            "virtual"
        ]
    },
    "MachineRegistry": {
        "Set": [
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer",
                "name": "DisableEdgeDesktopShortcutCreation",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Microsoft Edge short added to the public desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\EdgeUpdate",
                "name": "CreateDesktopShortcutDefault",
                "value": "0",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge shortcut from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\EdgeUpdate",
                "name": "RemoveDesktopShortcutDefault",
                "value": "1",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge shortcut from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
                "name": "SearchbarAllowed",
                "value": "0",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge search bar from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\FontSubstitutes",
                "name": "MS Shell Dlg",
                "value": "Tahoma",
                "type": "String",
                "note": "Replaces the `MS Shell Dlg` font with `Tahoma` for UI consistency"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\FontSubstitutes",
                "name": "MS Shell Dlg 2",
                "value": "Tahoma",
                "type": "String",
                "note": "Replaces the `MS Shell Dlg 2` font with `Tahoma` for UI consistency"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\CapabilityAccessManager\\ConsentStore\\location",
                "name": "Value",
                "value": "Allow",
                "type": "String",
                "note": "Enables location services"
            },
            {
                "path": "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\tzautoupdate",
                "name": "Start",
                "value": 3,
                "type": "DWord",
                "note": "Enable Set time zone automatically"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer",
                "name": "DisableEdgeDesktopShortcutCreation",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Microsoft Edge short added to the public desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\EdgeUpdate",
                "name": "CreateDesktopShortcutDefault",
                "value": "0",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge shortcut from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\EdgeUpdate",
                "name": "RemoveDesktopShortcutDefault",
                "value": "1",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge shortcut from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
                "name": "SearchbarAllowed",
                "value": "0",
                "type": "Dword",
                "note": "Prevent the Microsoft Edge search bar from being added to the desktop"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\FontSubstitutes",
                "name": "MS Shell Dlg",
                "value": "Tahoma",
                "type": "String",
                "note": "Replaces the `MS Shell Dlg` font with `Tahoma` for UI consistency"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\FontSubstitutes",
                "name": "MS Shell Dlg 2",
                "value": "Tahoma",
                "type": "String",
                "note": "Replaces the `MS Shell Dlg 2` font with `Tahoma` for UI consistency"
            },
            {
                "path": "HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\CapabilityAccessManager\\ConsentStore\\location",
                "name": "Value",
                "value": "Allow",
                "type": "String",
                "note": "Enables location services"
            }
        ]
    },
    "Paths": {
        "Remove": [
            "C:\\Users\\Public\\Desktop\\Microsoft Edge.lnk",
            "C:\\Users\\Public\\Music\\Sample Music",
            "C:\\Users\\Public\\Pictures\\Sample Pictures",
            "C:\\Users\\Public\\Videos\\Sample Videos",
            "C:\\Users\\Public\\Recorded TV\\Sample Media",
            "C:\\Logs"
        ]
    },
    "Features": {
        "Disable": [
            "Printing-XPSServices-Features",
            "SMB1Protocol",
            "WorkFolders-Client",
            "FaxServicesClientPackage",
            "WindowsMediaPlayer",
            "MicrosoftWindowsPowerShellV2Root",
            "MicrosoftWindowsPowerShellV2"
        ]
    },
    "Capabilities": {
        "Remove": [
            "Media.WindowsMediaPlayer~~~~0.0.12.0",
            "XPS.Viewer~~~~0.0.1.0",
            "Microsoft.Windows.WordPad~~~~0.0.1.0",
            "Print.Fax.Scan~~~~0.0.1.0",
            "Print.Management.Console~~~~0.0.1.0"
        ],
        "Others": [
            "App.Support.QuickAssist~~~~0.0.1.0",
            "MathRecognizer~~~~0.0.1.0",
            "Browser.InternetExplorer~~~~0.0.11.0",
            "Print.Fax.Scan~~~~0.0.1.0",
            "Microsoft.Windows.PowerShell.ISE~~~~0.0.1.0"
        ]
    },
    "Packages": {
        "Remove": [
            "Microsoft-Windows-MediaPlayer-Package*"
        ]
    },
    "Shortcuts": {
        "Edit": [
            {
                "Path": "C:\\ProgramData\\Microsoft\\Windows\\Start Menu\\Programs\\Microsoft Edge.lnk",
                "Arguments": "--no-first-run --disable-first-run-ui"
            }
        ]
    },
    "Services": {
        "Restart": [],
        "Stop": [],
        "Start": [
            "tzautoupdate"
        ]
    }
}