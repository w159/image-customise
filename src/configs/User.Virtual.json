{
    "$schema": "https://raw.githubusercontent.com/aaronparker/defaults/refs/heads/main/schema/configuration.schema.json",
    "Description": "Default user profile settings for all Windows editions on virtual machines",
    "MinimumBuild": "10.0.14393.0",
    "MaximumBuild": "10.0.99999.0",
    "Targets": {
        "Platforms": [
            "client",
            "multisession",
            "rds-server",
            "server"
        ],
        "Models": [
            "virtual"
        ]
    },
    "MachineRegistry": {
        "ChangeOwner": [],
        "Set": [],
        "Remove": []
    },
    "UserRegistry": {
        "Source": "https://learn.microsoft.com/en-us/windows-server/remote/remote-desktop-services/rds-vdi-recommendations-2004",
        "Set": [
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize",
                "name": "EnableBlurBehind",
                "value": 0,
                "type": "DWord",
                "note": "Disable blur for the Start menu, Taskbar and windows",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize",
                "name": "EnableTransparency",
                "value": 0,
                "type": "DWord",
                "note": "Disable transparency for the Start menu, Taskbar and windows",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "IconsOnly",
                "value": 1,
                "type": "DWord",
                "note": "Show icons only and not document previews",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "ListviewAlphaSelect",
                "value": 0,
                "type": "DWord",
                "note": "Disables the translucent selection rectangle in File Explorer",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "ListviewShadow",
                "value": 0,
                "type": "DWord",
                "note": "Disables drop shadows on icons in File Explorer",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "ShowCompColor",
                "value": 1,
                "type": "DWord",
                "note": "Changes the font colour for compressed NTFS files / directories",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "ShowInfoTip",
                "value": 1,
                "type": "DWord",
                "note": "Disables tooltips in File Explorer",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
                "name": "TaskbarAnimations",
                "value": 0,
                "type": "DWord",
                "note": "Disables animations in the Taskbar",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\DWM",
                "name": "EnableAeroPeek",
                "value": 0,
                "type": "DWord",
                "note": "Disables Peek at desktop and Taskbar thumbnail live previews",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\DWM",
                "name": "AlwaysHibernateThumbnails",
                "value": 0,
                "type": "DWord",
                "note": "Disables Taskbar preview thumbnail cache",
                "protected": false
            },
            {
                "path": "HKCU:\\Control Panel\\Desktop",
                "name": "DragFullWindows",
                "value": "1",
                "type": "String",
                "note": "Disables the display of the window contents when dragging",
                "protected": false
            },
            {
                "path": "HKCU:\\Control Panel\\Desktop\\WindowMetrics",
                "name": "MinAnimate",
                "value": "0",
                "type": "String",
                "note": "Disables animations for minimise and maximise actions for windows",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
                "name": "SubscribedContent-310093Enabled",
                "value": 0,
                "type": "DWord",
                "note": "Disables 'Show me the Windows welcome experience after updates and occasionally when I sign in to highlight what's new and suggested'",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\BackgroundAccessApplications\\Microsoft.Windows.Photos_8wekyb3d8bbwe",
                "name": "Disabled",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Photos app from running in the background",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\BackgroundAccessApplications\\Microsoft.Windows.Photos_8wekyb3d8bbwe",
                "name": "DisabledByUser",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Photos app from running in the background",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\BackgroundAccessApplications\\Microsoft.YourPhone_8wekyb3d8bbwe",
                "name": "Disabled",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Your Phone app from running in the background",
                "protected": false
            },
            {
                "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\BackgroundAccessApplications\\Microsoft.YourPhone_8wekyb3d8bbwe",
                "name": "DisabledByUser",
                "value": 1,
                "type": "DWord",
                "note": "Prevents the Your Phone app from running in the background",
                "protected": false
            }
        ]
    },
    "Paths": {
        "Remove": []
    },
    "Features": {
        "Disable": []
    },
    "Capabilities": {
        "Remove": [],
        "Others": []
    },
    "Packages": {
        "Remove": []
    },
    "Shortcuts": {
        "Edit": []
    },
    "Services": {
        "Restart": [],
        "Stop": [],
        "Start": []
    },
    "Files": {
        "Copy": []
    }
}